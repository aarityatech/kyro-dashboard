[Unit]
Description=Kyro dashboard refresh (S3 sync + rebuild + publish)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# adjust User / WorkingDirectory to match your instance
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/kyro-dashboard
Environment=AWS_DEFAULT_REGION=ap-south-1
ExecStart=/home/ubuntu/kyro-dashboard/refresh.sh
# logs -> journalctl -u kyro-refresh.service
